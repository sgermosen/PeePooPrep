<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PeePooFinder"
             xmlns:converters="clr-namespace:PeePooFinder.Converters"
             x:Class="PeePooFinder.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InvertedBoolConverter x:Key="InvertedBool" />
            <converters:StringHasValueConverter x:Key="StringHasValue" />
            <converters:RatingToStarsConverter x:Key="RatingToStars" />
            <converters:NotNullConverter x:Key="NotNull" />
            <converters:BoolToYesNoConverter x:Key="BoolToYesNo" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
